  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>ITI</DataSourceName>
        <CommandText>SELECT 
    
T.Top_name,
    
C.Crs_name,
    
C.Crs_duration

FROM Course C
JOIN Topic T ON C.Top_id = T.Top_id;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
